rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation helpers
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
        && data.fullName is string && data.fullName.size() <= 200
        && (data.phoneNumber == null || (data.phoneNumber is string && data.phoneNumber.size() <= 30))
        && (data.state == null || (data.state is string && data.state.size() <= 100))
        && (data.city == null || (data.city is string && data.city.size() <= 100))
        && (data.aadhaarLastFour == null || (data.aadhaarLastFour is string && data.aadhaarLastFour.size() <= 10))
        && (data.digitalCardId == null || (data.digitalCardId is string && data.digitalCardId.size() <= 100))
        && (data.savedDocuments == null || (data.savedDocuments is list && data.savedDocuments.size() <= 50));
    }

    function isValidComplaint(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.category is string && data.category.size() <= 100
        && data.description is string && data.description.size() <= 2000
        && data.locationName is string && data.locationName.size() <= 500
        && data.coordinates is map
        && data.state is string && data.state.size() <= 100
        && data.createdAt is string && data.createdAt.size() <= 100
        && data.status is string && data.status.size() <= 100
        && data.timeline is list && data.timeline.size() <= 50
        && data.upvotes is int;
    }

    function isValidAppliedScheme(data) {
      return data.id is string && data.id.size() <= 128
        && data.schemeId is string && data.schemeId.size() <= 128
        && data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 300
        && data.department is string && data.department.size() <= 300
        && data.status is string && data.status.size() <= 100
        && data.applicationId is string && data.applicationId.size() <= 100
        && data.appliedDate is string && data.appliedDate.size() <= 100;
    }

    // Rules matching
    
    // User profile rule
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Block user list scraping
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phoneNumber', 'state', 'city', 'aadhaarLastFour', 'digitalCardId', 'savedDocuments'])
      );
      allow delete: if false;
      
      // User's applied schemes sub-collection
      match /appliedSchemes/{schemeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAppliedScheme(incoming());
        allow update: if isOwner(userId) && isValidAppliedScheme(incoming()) && incoming().id == existing().id;
        allow delete: if isOwner(userId);
      }
    }

    // Complaints rule
    match /complaints/{complaintId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidComplaint(incoming());
      allow update: if isSignedIn() && (
        // Action 1: Owner updates details of their own complaint
        (existing().userId == request.auth.uid && incoming().userId == request.auth.uid && incoming().id == existing().id && isValidComplaint(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'description', 'locationName', 'coordinates', 'state', 'timeline', 'status'])
        )) ||
        // Action 2: Any signed-in user upvotes a complaint
        (incoming().diff(existing()).affectedKeys().hasOnly(['upvotes']))
      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
